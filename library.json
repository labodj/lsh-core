{
  "$schema": "https://raw.githubusercontent.com/platformio/platformio-core/develop/platformio/assets/schema/library.json",
  "name": "lsh-core",
  "version": "3.0.5",
  "description": "Deterministic C++ framework for Arduino/Controllino controllers in the LSH ecosystem.",
  "keywords": [
    "arduino",
    "controllino",
    "avr",
    "embedded",
    "automation",
    "relay",
    "buttons",
    "msgpack",
    "serial"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/labodj/lsh-core.git"
  },
  "authors": [
    {
      "name": "Jacopo Labardi",
      "email": "2527836+labodj@users.noreply.github.com",
      "maintainer": true
    }
  ],
  "license": "Apache-2.0",
  "homepage": "https://labodj.github.io/lsh-core/",
  "frameworks": "arduino",
  "platforms": "atmelavr",
  "dependencies": {
    "etlcpp/Embedded Template Library": "20.47.1",
    "bblanchon/ArduinoJson": "^6.21.6"
  },
  "build": {
    "libLDFMode": "deep+"
  },
  "export": {
    "include": [
      "CITATION.cff",
      "LICENSE",
      "NOTICE",
      "README.md",
      "docs/cookbook.md",
      "docs/lsh_devices.schema.json",
      "docs/static-toml-config.md",
      "examples/avr-board-matrix/README.md",
      "examples/avr-board-matrix/lsh_devices.lock.toml",
      "examples/avr-board-matrix/lsh_devices.toml",
      "examples/avr-board-matrix/platformio.ini",
      "examples/avr-board-matrix/src/*",
      "examples/cookbook/README.md",
      "examples/cookbook/lsh_devices.toml",
      "include/*",
      "library.json",
      "src/*",
      "tools/__init__.py",
      "tools/generate_lsh_static_config.py",
      "tools/lsh_static_config/*",
      "tools/migrate_lsh_config.py",
      "tools/platformio_lsh_static_config.py"
    ]
  }
}
